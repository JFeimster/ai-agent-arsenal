{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tool Action",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string" },
    "description": { "type": "string" },
    "endpoint": { "type": "string" },
    "auth": {
      "type": "string",
      "enum": ["none", "apiKey", "oauth", "manual-review"]
    }
  },
  "required": ["title", "endpoint"]
}
